# ── Wise Standards ───────────────────────────────────────────────────────────
# Path to the wise-standards repo (for make sync-standards)
WISE_STANDARDS_PATH=../wise-standards

# ── Google Cloud ─────────────────────────────────────────────────────────────
PROJECT_ID=your-gcp-project-id
SERVICE_NAME=your-service-name
REGION=europe-west1

# ── Supabase Auth (optional) ─────────────────────────────────────────────────
# Set SUPABASE_AUTH_ENABLED=true to gate the app behind Supabase login.
# When false or absent, the app runs without authentication.
# URL and keys from Supabase Dashboard → Settings → API
# SUPABASE_KEY = anon/public key (used browser-side for login)
# SUPABASE_SERVICE_ROLE_KEY = service role key (used server-side for JWT verification)
SUPABASE_AUTH_ENABLED=false
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-publishable-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Cloud SQL (optional) ────────────────────────────────────────────────────
# Uncomment if the project uses Cloud SQL via the Auth Proxy.
# Format: <project-id>:<region>:<instance-name>
# CLOUD_SQL_INSTANCE=my-project:europe-west1:my-instance
# DB_HOST=127.0.0.1
# DB_PORT=5432
# DB_NAME=my-database
# DB_USER=***
# DB_PASSWORD=***

# ── FusionSolar API (optional) ────────────────────────────────────────────────
# Uncomment if the project integrates with Huawei FusionSolar.
# Nuxt: prefix with NUXT_ (e.g., NUXT_FUSIONSOLAR_URL)
# FUSIONSOLAR_URL=https://eu5.fusionsolar.huawei.com
# FUSIONSOLAR_USER=your-fusionsolar-user
# FUSIONSOLAR_PASSWORD=your-fusionsolar-password

# ── App ──────────────────────────────────────────────────────────────────────
# PORT=8080
